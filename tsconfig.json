{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.js", "src/**/*.ts", "src/**/*.d.ts", "__tests__/**/*.ts"],
  "exclude": ["node_modules", "src/generated", "dist", "**/*.cjs"]
}
