{
  "name": "@oscarhermoso/magic-card-parser",
  "version": "0.4.0",
  "description": "A utility for parsing magic cards into a JSON structure for further processing.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "build:grammar": "sh nearley/helper.sh",
    "build:bundle": "tsup && cp src/index.d.ts dist/index.d.ts",
    "build": "npm run build:grammar && npm run build:bundle",
    "typecheck": "tsc --noEmit",
    "clean": "rm -r src/generated",
    "test": "vitest run",
    "test:watch": "vitest",
    "assess": "npm run build && node --max-old-space-size=8192 scripts/assessCardParser.js",
    "fetch": "node scripts/fetchCards.js",
    "visualize": "npm run build && node scripts/visualizeCard.js",
    "generate": "npm run build && node --max-old-space-size=30720 node_modules/nearley/bin/nearley-unparse.js src/generated/magicCardGrammar.js -n 5",
    "railroad": "nearley-railroad nearley/magicCard.ne > railroad.html",
    "prepublishOnly": "npm run build"
  },
  "directories": {
    "lib": "src",
    "example": "scripts",
    "test": "__tests__"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oscarhermoso/magic-card-parser.git"
  },
  "homepage": "https://github.com/oscarhermoso/magic-card-parser",
  "bugs": {
    "url": "https://github.com/oscarhermoso/magic-card-parser/issues",
    "email": "friends.devon@gmail.com"
  },
  "author": {
    "name": "ruler501",
    "email": "friends.devon@gmail.com"
  },
  "license": "MIT",
  "keywords": [
    "mtg",
    "magic"
  ],
  "dependencies": {
    "nearley": "^2.19.5"
  },
  "devDependencies": {
    "@types/nearley": "^2.11.5",
    "@types/node": "^25.5.0",
    "graphviz": "0.0.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
